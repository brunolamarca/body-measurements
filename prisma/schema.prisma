generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id           String        @id @default(cuid())
  name         String
  birthdate    DateTime?
  gender       String?
  heightCm     Float?
  avatarColor  String        @default("#3b82f6")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  measurements Measurement[]
}

model Measurement {
  id                String   @id @default(cuid())
  profileId         String
  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date              DateTime
  weightKg          Float?
  waistAboveNavelCm Float?
  waistNavelCm      Float?
  rightArmCm        Float?
  leftArmCm         Float?
  rightForearmCm    Float?
  leftForearmCm     Float?
  glutesCm          Float?
  rightThighCm      Float?
  leftThighCm       Float?
  rightCalfCm       Float?
  leftCalfCm        Float?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([profileId, date])
}
